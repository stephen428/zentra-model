# Copy this file to .env.local and fill in the values
# Do NOT commit .env.local to Git

# Generate a random secret — run this in your terminal:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=your-random-secret-here

# Your Vercel deployment URL (no trailing slash)
NEXTAUTH_URL=https://zentra-model.vercel.app

# Vercel KV — copy these from your Vercel dashboard after creating a KV store
# Dashboard → Storage → Create → KV → copy the connection strings
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
